# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Microsoft App Registration (from Azure Portal)
# Get this from: https://portal.azure.com → App registrations → Your app → Application (client) ID
MICROSOFT_CLIENT_ID=your_client_id_here

# Timezone (default: Asia/Phnom_Penh)
TIMEZONE=Asia/Phnom_Penh

# Gemini API Key (Required for image parsing / smart extraction)
# Get a free key from https://aistudio.google.com/

